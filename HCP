function Get-HCPCustomer {
    <#
    .SYNOPSIS
        Gets a single customer by ID, or lists/searches customers.
    .PARAMETER CustomerId
        Return only this customer.
    .PARAMETER Search
        Free-text search (the API's 'q' parameter).
    .PARAMETER All
        Follow pagination and return every matching customer.
    .EXAMPLE
        Get-HCPCustomer -Search 'smith'
    .EXAMPLE
        Get-HCPCustomer -All
    #>
    [CmdletBinding(DefaultParameterSetName = 'List')]
    param(
        [Parameter(ParameterSetName = 'ById', Mandatory, Position = 0, ValueFromPipeline, ValueFromPipelineByPropertyName)]
        [Alias('id')]
        [string]$CustomerId,

        [Parameter(ParameterSetName = 'List')]
        [Alias('q')]
        [string]$Search,

        [Parameter(ParameterSetName = 'List')]
        [int]$Page,

        [Parameter(ParameterSetName = 'List')]
        [int]$PageSize,

        [Parameter(ParameterSetName = 'List')]
        [switch]$All
    )

    process {
        if ($PSCmdlet.ParameterSetName -eq 'ById') {
            return Invoke-HCPApi -Method GET -Path "/customers/$CustomerId"
        }

        $query = @{}
        if ($Search)   { $query.q = $Search }
        if ($Page)     { $query.page = $Page }
        if ($PageSize) { $query.page_size = $PageSize }
        Invoke-HCPPagedApi -Path '/customers' -CollectionName 'customers' -Query $query -All:$All
    }
}

function New-HCPCustomer {
    <#
    .SYNOPSIS
        Creates a customer.
    .PARAMETER Addresses
        Array of address hashtables, e.g.
        @{ type='service'; street='123 Main St'; city='Austin'; state='TX'; zip='78701' }
    .PARAMETER Properties
        Extra body fields to pass through verbatim (merged last).
    .EXAMPLE
        New-HCPCustomer -FirstName 'Jane' -LastName 'Doe' -Email 'jane@example.com' -MobileNumber '5125550100'
    #>
    [CmdletBinding(SupportsShouldProcess)]
    param(
        [string]$FirstName,
        [string]$LastName,
        [string]$Email,
        [string]$MobileNumber,
        [string]$HomeNumber,
        [string]$WorkNumber,
        [string]$Company,
        [bool]$NotificationsEnabled,
        [string]$LeadSource,
        [string[]]$Tags,
        [hashtable[]]$Addresses,
        [hashtable]$Properties
    )

    $body = @{}
    if ($PSBoundParameters.ContainsKey('FirstName'))            { $body.first_name = $FirstName }
    if ($PSBoundParameters.ContainsKey('LastName'))             { $body.last_name = $LastName }
    if ($PSBoundParameters.ContainsKey('Email'))                { $body.email = $Email }
    if ($PSBoundParameters.ContainsKey('MobileNumber'))         { $body.mobile_number = $MobileNumber }
    if ($PSBoundParameters.ContainsKey('HomeNumber'))           { $body.home_number = $HomeNumber }
    if ($PSBoundParameters.ContainsKey('WorkNumber'))           { $body.work_number = $WorkNumber }
    if ($PSBoundParameters.ContainsKey('Company'))              { $body.company = $Company }
    if ($PSBoundParameters.ContainsKey('NotificationsEnabled')) { $body.notifications_enabled = $NotificationsEnabled }
    if ($PSBoundParameters.ContainsKey('LeadSource'))           { $body.lead_source = $LeadSource }
    if ($PSBoundParameters.ContainsKey('Tags'))                 { $body.tags = $Tags }
    if ($PSBoundParameters.ContainsKey('Addresses'))            { $body.addresses = $Addresses }
    if ($Properties) { foreach ($key in $Properties.Keys) { $body[$key] = $Properties[$key] } }

    $display = (@($FirstName, $LastName) -join ' ').Trim()
    if (-not $display) { $display = $Company }
    if ($PSCmdlet.ShouldProcess($display, 'Create Housecall Pro customer')) {
        Invoke-HCPApi -Method POST -Path '/customers' -Body $body
    }
}

function Set-HCPCustomer {
    <#
    .SYNOPSIS
        Updates a customer.
    .EXAMPLE
        Set-HCPCustomer -CustomerId cus_123 -Email 'new@example.com'
    #>
    [CmdletBinding(SupportsShouldProcess)]
    param(
        [Parameter(Mandatory, Position = 0, ValueFromPipelineByPropertyName)]
        [Alias('id')]
        [string]$CustomerId,

        [string]$FirstName,
        [string]$LastName,
        [string]$Email,
        [string]$MobileNumber,
        [string]$HomeNumber,
        [string]$WorkNumber,
        [string]$Company,
        [bool]$NotificationsEnabled,
        [string]$LeadSource,
        [string[]]$Tags,
        [hashtable[]]$Addresses,
        [hashtable]$Properties
    )

    process {
        $body = @{}
        if ($PSBoundParameters.ContainsKey('FirstName'))            { $body.first_name = $FirstName }
        if ($PSBoundParameters.ContainsKey('LastName'))             { $body.last_name = $LastName }
        if ($PSBoundParameters.ContainsKey('Email'))                { $body.email = $Email }
        if ($PSBoundParameters.ContainsKey('MobileNumber'))         { $body.mobile_number = $MobileNumber }
        if ($PSBoundParameters.ContainsKey('HomeNumber'))           { $body.home_number = $HomeNumber }
        if ($PSBoundParameters.ContainsKey('WorkNumber'))           { $body.work_number = $WorkNumber }
        if ($PSBoundParameters.ContainsKey('Company'))              { $body.company = $Company }
        if ($PSBoundParameters.ContainsKey('NotificationsEnabled')) { $body.notifications_enabled = $NotificationsEnabled }
        if ($PSBoundParameters.ContainsKey('LeadSource'))           { $body.lead_source = $LeadSource }
        if ($PSBoundParameters.ContainsKey('Tags'))                 { $body.tags = $Tags }
        if ($PSBoundParameters.ContainsKey('Addresses'))            { $body.addresses = $Addresses }
        if ($Properties) { foreach ($key in $Properties.Keys) { $body[$key] = $Properties[$key] } }

        if ($body.Count -eq 0) { throw 'Specify at least one property to update.' }

        if ($PSCmdlet.ShouldProcess($CustomerId, 'Update Housecall Pro customer')) {
            Invoke-HCPApi -Method PUT -Path "/customers/$CustomerId" -Body $body
        }
    }
}

