#Requires -Version 5.1
<#
.SYNOPSIS
    HouseCallPro - PowerShell module for the Housecall Pro Public API.

.DESCRIPTION
    Wraps the Housecall Pro Public API (https://docs.housecallpro.com/) with
    PowerShell-friendly cmdlets. Covers customers, leads, jobs, line items,
    appointments, estimates, invoices, payments, employees, companies, and
    webhook subscriptions.

    Authentication: the API is available to Pros on the MAX plan. Generate an
    API key from the App Store API card in Housecall Pro, then run:

        Connect-HCPApi -ApiKey 'your-key-here'

    NOTE: All monetary amounts returned by the API are integers in cents.
#>

# ---------------------------------------------------------------------------
# Module state
# ---------------------------------------------------------------------------

$script:HCPConfig = [pscustomobject]@{
    BaseUri    = 'https://api.housecallpro.com'
    ApiKey     = $null          # SecureString
    AuthScheme = 'Token'        # 'Token' (API key) or 'Bearer' (OAuth access token)
    MaxRetries = 3
}

$script:HCPCredentialPath = Join-Path ([Environment]::GetFolderPath('ApplicationData')) 'HouseCallPro\connection.xml'

function ConvertFrom-SecureStringPlain {
    [CmdletBinding()]
    param([Parameter(Mandatory)][securestring]$SecureString)

    $bstr = [Runtime.InteropServices.Marshal]::SecureStringToBSTR($SecureString)
    try {
        [Runtime.InteropServices.Marshal]::PtrToStringBSTR($bstr)
    }
    finally {
        [Runtime.InteropServices.Marshal]::ZeroFreeBSTR($bstr)
    }
}

# ---------------------------------------------------------------------------
# Connection management
# ---------------------------------------------------------------------------

function Connect-HCPApi {
    <#
    .SYNOPSIS
        Stores the Housecall Pro API key for use by the other cmdlets.
    .PARAMETER ApiKey
        The API key from your Housecall Pro App Store API card. Accepts a
        plain string or a SecureString.
    .PARAMETER AuthScheme
        'Token' for API keys (default) or 'Bearer' for OAuth 2.0 access tokens.
    .PARAMETER BaseUri
        Override the API base URI. Defaults to https://api.housecallpro.com.
    .PARAMETER Persist
        Save the connection (DPAPI-encrypted, current user/machine only) so
        future sessions reconnect automatically on module import.
    .EXAMPLE
        Connect-HCPApi -ApiKey 'abc123' -Persist
    #>
    [CmdletBinding()]
    param(
        [Parameter(Mandatory, Position = 0)]
        [object]$ApiKey,

        [ValidateSet('Token', 'Bearer')]
        [string]$AuthScheme = 'Token',

        [string]$BaseUri,

        [switch]$Persist
    )

    $secure = if ($ApiKey -is [securestring]) { $ApiKey }
              else { ConvertTo-SecureString -String ([string]$ApiKey) -AsPlainText -Force }

    $script:HCPConfig.ApiKey     = $secure
    $script:HCPConfig.AuthScheme = $AuthScheme
    if ($BaseUri) { $script:HCPConfig.BaseUri = $BaseUri.TrimEnd('/') }

    if ($Persist) {
        $dir = Split-Path $script:HCPCredentialPath -Parent
        if (-not (Test-Path $dir)) { New-Item -ItemType Directory -Path $dir -Force | Out-Null }
        [pscustomobject]@{
            ApiKey     = $secure | ConvertFrom-SecureString
            AuthScheme = $script:HCPConfig.AuthScheme
            BaseUri    = $script:HCPConfig.BaseUri
        } | Export-Clixml -Path $script:HCPCredentialPath
        Write-Verbose "Connection saved to $script:HCPCredentialPath"
    }

    Write-Verbose "Connected to $($script:HCPConfig.BaseUri) using $AuthScheme auth."
}

function Disconnect-HCPApi {
    <#
    .SYNOPSIS
        Clears the stored API key and removes any persisted connection.
    #>
    [CmdletBinding()]
    param()

    $script:HCPConfig.ApiKey = $null
    if (Test-Path $script:HCPCredentialPath) {
        Remove-Item $script:HCPCredentialPath -Force
    }
}

function Get-HCPConnection {
    <#
    .SYNOPSIS
        Shows the current connection settings (the key itself is not revealed).
    #>
    [CmdletBinding()]
    param()

    [pscustomobject]@{
        BaseUri    = $script:HCPConfig.BaseUri
        AuthScheme = $script:HCPConfig.AuthScheme
        Connected  = [bool]$script:HCPConfig.ApiKey
        Persisted  = Test-Path $script:HCPCredentialPath
    }
}

function Restore-HCPConnection {
    # Internal: reload a persisted connection on module import.
    if (Test-Path $script:HCPCredentialPath) {
        try {
            $saved = Import-Clixml -Path $script:HCPCredentialPath
            $script:HCPConfig.ApiKey     = $saved.ApiKey | ConvertTo-SecureString
            $script:HCPConfig.AuthScheme = $saved.AuthScheme
            $script:HCPConfig.BaseUri    = $saved.BaseUri
        }
        catch {
            Write-Warning "Could not restore saved Housecall Pro connection: $_"
        }
    }
}

# ---------------------------------------------------------------------------
# Core request engine
# ---------------------------------------------------------------------------

function Invoke-HCPApi {
    <#
    .SYNOPSIS
        Sends a raw request to the Housecall Pro API. Used by every other
        cmdlet; also exported for endpoints not yet wrapped.
    .PARAMETER Method
        HTTP method (GET, POST, PUT, PATCH, DELETE).
    .PARAMETER Path
        Path relative to the base URI, e.g. '/customers' or 'jobs/job_123'.
    .PARAMETER Query
        Hashtable of query string parameters. Array values are repeated
        (e.g. employee_ids[]).
    .PARAMETER Body
        Hashtable or PSCustomObject serialized to JSON for the request body.
    .EXAMPLE
        Invoke-HCPApi -Method GET -Path '/customers' -Query @{ page_size = 50 }
    #>
    [CmdletBinding()]
    param(
        [ValidateSet('GET', 'POST', 'PUT', 'PATCH', 'DELETE')]
        [string]$Method = 'GET',

        [Parameter(Mandatory, Position = 0)]
        [string]$Path,

        [hashtable]$Query,

        [object]$Body
    )

    if (-not $script:HCPConfig.ApiKey) {
        throw "Not connected to the Housecall Pro API. Run Connect-HCPApi first."
    }

    # Build URI with query string
    $uri = '{0}/{1}' -f $script:HCPConfig.BaseUri, $Path.TrimStart('/')
    if ($Query -and $Query.Count -gt 0) {
        $pairs = foreach ($key in $Query.Keys) {
            $value = $Query[$key]
            if ($null -eq $value) { continue }
            if ($value -is [System.Collections.IEnumerable] -and $value -isnot [string]) {
                foreach ($item in $value) {
                    '{0}={1}' -f [uri]::EscapeDataString("$key[]"), [uri]::EscapeDataString([string]$item)
                }
            }
            else {
                '{0}={1}' -f [uri]::EscapeDataString($key), [uri]::EscapeDataString([string]$value)
            }
        }
        if ($pairs) { $uri += '?' + ($pairs -join '&') }
    }

    $plainKey = ConvertFrom-SecureStringPlain -SecureString $script:HCPConfig.ApiKey
    $headers = @{
        Authorization = '{0} {1}' -f $script:HCPConfig.AuthScheme, $plainKey
        Accept        = 'application/json'
    }

    $requestParams = @{
        Method      = $Method
        Uri         = $uri
        Headers     = $headers
        ErrorAction = 'Stop'
    }
    if ($null -ne $Body) {
        $requestParams.Body        = ($Body | ConvertTo-Json -Depth 20)
        $requestParams.ContentType = 'application/json'
    }

    $attempt = 0
    while ($true) {
        $attempt++
        try {
            Write-Verbose "$Method $uri (attempt $attempt)"
            return Invoke-RestMethod @requestParams
        }
        catch {
            $statusCode = $null
            $retryAfter = $null
            if ($_.Exception.Response) {
                $statusCode = [int]$_.Exception.Response.StatusCode
                try { $retryAfter = $_.Exception.Response.Headers['Retry-After'] } catch { }
            }

            # Retry on rate limiting and transient server errors
            $retryable = $statusCode -in 429, 500, 502, 503, 504
            if ($retryable -and $attempt -le $script:HCPConfig.MaxRetries) {
                $delay = if ($retryAfter) { [double]$retryAfter } else { [math]::Pow(2, $attempt) }
                Write-Warning "HTTP $statusCode from Housecall Pro; retrying in $delay second(s)..."
                Start-Sleep -Seconds $delay
                continue
            }

            # Surface the API's error body when available
            $detail = $null
            try {
                if ($_.ErrorDetails.Message) { $detail = $_.ErrorDetails.Message }
                elseif ($_.Exception.Response -and $_.Exception.Response.GetResponseStream) {
                    $reader = [IO.StreamReader]::new($_.Exception.Response.GetResponseStream())
                    $detail = $reader.ReadToEnd()
                }
            }
            catch { }

            $message = "Housecall Pro API request failed: $Method $uri"
            if ($statusCode) { $message += " (HTTP $statusCode)" }
            if ($detail)     { $message += "`n$detail" }
            throw $message
        }
    }
}

function Invoke-HCPPagedApi {
    # Internal: GET a collection endpoint, unwrapping the named collection
    # property and optionally following page/page_size pagination to the end.
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)][string]$Path,
        [Parameter(Mandatory)][string]$CollectionName,
        [hashtable]$Query = @{},
        [switch]$All
    )

    $query = @{} + $Query
    if (-not $query.ContainsKey('page_size')) { $query.page_size = 100 }
    $page = if ($query.ContainsKey('page')) { [int]$query.page } else { 1 }

    do {
        $query.page = $page
        $response = Invoke-HCPApi -Method GET -Path $Path -Query $query

        $items = if ($response.PSObject.Properties[$CollectionName]) { $response.$CollectionName }
                 else { $response }
        if ($null -eq $items) { break }
        $items | Write-Output

        $count = @($items).Count
        $page++
    } while ($All -and $count -eq [int]$query.page_size)
}

