function Get-HCPWebhook {
    <#
    .SYNOPSIS
        Lists webhook subscriptions.
    #>
    [CmdletBinding()]
    param()

    Invoke-HCPPagedApi -Path '/webhooks' -CollectionName 'webhooks'
}

function New-HCPWebhook {
    <#
    .SYNOPSIS
        Creates a webhook subscription. Events cover customer, estimate,
        invoice, job, lead, and payment changes.
    .EXAMPLE
        New-HCPWebhook -Url 'https://example.com/hcp-hook' -Events 'job.completed','invoice.paid'
    #>
    [CmdletBinding(SupportsShouldProcess)]
    param(
        [Parameter(Mandatory, Position = 0)]
        [string]$Url,

        [string[]]$Events,

        [hashtable]$Properties
    )

    $body = @{ url = $Url }
    if ($Events)     { $body.events = $Events }
    if ($Properties) { foreach ($key in $Properties.Keys) { $body[$key] = $Properties[$key] } }

    if ($PSCmdlet.ShouldProcess($Url, 'Create Housecall Pro webhook subscription')) {
        Invoke-HCPApi -Method POST -Path '/webhooks' -Body $body
    }
}

function Remove-HCPWebhook {
    <#
    .SYNOPSIS
        Deletes a webhook subscription.
    #>
    [CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'High')]
    param(
        [Parameter(Mandatory, Position = 0, ValueFromPipeline, ValueFromPipelineByPropertyName)]
        [Alias('id')]
        [string]$WebhookId
    )

    process {
        if ($PSCmdlet.ShouldProcess($WebhookId, 'Delete Housecall Pro webhook subscription')) {
            Invoke-HCPApi -Method DELETE -Path "/webhooks/$WebhookId" | Out-Null
        }
    }
}

