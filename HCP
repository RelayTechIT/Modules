function Get-HCPInvoice {
    <#
    .SYNOPSIS
        Gets a single invoice by ID, or lists invoices.
    #>
    [CmdletBinding(DefaultParameterSetName = 'List')]
    param(
        [Parameter(ParameterSetName = 'ById', Mandatory, Position = 0, ValueFromPipeline, ValueFromPipelineByPropertyName)]
        [Alias('id')]
        [string]$InvoiceId,

        [Parameter(ParameterSetName = 'List')]
        [int]$Page,

        [Parameter(ParameterSetName = 'List')]
        [int]$PageSize,

        [Parameter(ParameterSetName = 'List')]
        [switch]$All
    )

    process {
        if ($PSCmdlet.ParameterSetName -eq 'ById') {
            return Invoke-HCPApi -Method GET -Path "/invoices/$InvoiceId"
        }

        $query = @{}
        if ($Page)     { $query.page = $Page }
        if ($PageSize) { $query.page_size = $PageSize }
        Invoke-HCPPagedApi -Path '/invoices' -CollectionName 'invoices' -Query $query -All:$All
    }
}

function New-HCPInvoice {
    <#
    .SYNOPSIS
        Creates an invoice.
    .PARAMETER Body
        Hashtable with the invoice payload.
    #>
    [CmdletBinding(SupportsShouldProcess)]
    param(
        [Parameter(Mandatory, Position = 0)]
        [hashtable]$Body
    )

    if ($PSCmdlet.ShouldProcess('invoice', 'Create Housecall Pro invoice')) {
        Invoke-HCPApi -Method POST -Path '/invoices' -Body $Body
    }
}

function Get-HCPInvoicePayment {
    <#
    .SYNOPSIS
        Lists the payments processed against an invoice.
    .EXAMPLE
        Get-HCPInvoice -All | Get-HCPInvoicePayment
    #>
    [CmdletBinding()]
    param(
        [Parameter(Mandatory, Position = 0, ValueFromPipeline, ValueFromPipelineByPropertyName)]
        [Alias('id')]
        [string]$InvoiceId
    )

    process {
        Invoke-HCPPagedApi -Path "/invoices/$InvoiceId/payments" -CollectionName 'payments'
    }
}

