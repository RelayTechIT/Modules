function Get-HCPJob {
    <#
    .SYNOPSIS
        Gets a single job by ID, or lists jobs with optional filters.
    .PARAMETER ScheduledStartMin
        Only jobs whose scheduled start is at or after this time.
    .PARAMETER ScheduledStartMax
        Only jobs whose scheduled start is at or before this time.
    .PARAMETER EmployeeIds
        Only jobs assigned to these employee IDs.
    .EXAMPLE
        Get-HCPJob -ScheduledStartMin (Get-Date).Date -ScheduledStartMax (Get-Date).Date.AddDays(1) -All
    #>
    [CmdletBinding(DefaultParameterSetName = 'List')]
    param(
        [Parameter(ParameterSetName = 'ById', Mandatory, Position = 0, ValueFromPipeline, ValueFromPipelineByPropertyName)]
        [Alias('id')]
        [string]$JobId,

        [Parameter(ParameterSetName = 'List')]
        [string]$CustomerId,

        [Parameter(ParameterSetName = 'List')]
        [datetime]$ScheduledStartMin,

        [Parameter(ParameterSetName = 'List')]
        [datetime]$ScheduledStartMax,

        [Parameter(ParameterSetName = 'List')]
        [string[]]$EmployeeIds,

        [Parameter(ParameterSetName = 'List')]
        [int]$Page,

        [Parameter(ParameterSetName = 'List')]
        [int]$PageSize,

        [Parameter(ParameterSetName = 'List')]
        [switch]$All
    )

    process {
        if ($PSCmdlet.ParameterSetName -eq 'ById') {
            return Invoke-HCPApi -Method GET -Path "/jobs/$JobId"
        }

        $query = @{}
        if ($CustomerId)        { $query.customer_id = $CustomerId }
        if ($ScheduledStartMin) { $query.scheduled_start_min = $ScheduledStartMin.ToUniversalTime().ToString('o') }
        if ($ScheduledStartMax) { $query.scheduled_start_max = $ScheduledStartMax.ToUniversalTime().ToString('o') }
        if ($EmployeeIds)       { $query.employee_ids = $EmployeeIds }
        if ($Page)              { $query.page = $Page }
        if ($PageSize)          { $query.page_size = $PageSize }
        Invoke-HCPPagedApi -Path '/jobs' -CollectionName 'jobs' -Query $query -All:$All
    }
}

